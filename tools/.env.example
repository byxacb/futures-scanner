# 复制为 .env 并填入真实 API Key。.env 必须在 .gitignore 中。
# ⚠️ 永远不要把 key 粘贴到聊天/截图/git commit 里——只在这个本地文件中保存

# === Anthropic 兼容协议（小米 MiMo via token-plan 等代理也走这个） ===
# ANTHROPIC_API_KEY=tp-填你自己的key（重置后的）
# ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
# ANTHROPIC_MODEL=mimo-v2.5-pro
#
# 官方 Anthropic 用法（如果你将来切回官方）：
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# === DeepSeek（备选，便宜且中文好） ===
# DEEPSEEK_API_KEY=sk-your-key-here

# === 智谱 GLM（备选） ===
# ZHIPU_API_KEY=your-zhipu-key.with.dot

# === 豆包（备选） ===
# DOUBAO_API_KEY=your-doubao-key
# DOUBAO_MODEL_ID=ep-your-endpoint-id

# === 通义千问（备选） ===
# DASHSCOPE_API_KEY=sk-your-key
